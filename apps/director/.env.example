# Director — env vars
#
# Copy to `apps/director/.env` (or repo root `.env`) and fill in.
# The Electron main process loads dotenv from both locations on boot
# (repo root takes precedence). The renderer NEVER sees OPENAI_API_KEY —
# main mints short-lived ephemeral Realtime tokens for the renderer.

# Required: OpenAI API key with access to gpt-realtime-2.
OPENAI_API_KEY=sk-...

# Optional: override Realtime model id (defaults to gpt-realtime-2).
# OPENAI_REALTIME_MODEL=gpt-realtime-2

# Optional: override voice ("marin" or "cedar"; defaults to marin).
# OPENAI_REALTIME_VOICE=marin
